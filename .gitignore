# is commented out by default.
#.vscode/

# Flutter/Dart/Pub related
**/doc/api/
**/ios/Flutter/.last_build_id
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Superpowers brainstorm cache (local mockups + server state)
.superpowers/

# Git worktrees
.worktrees/

# Claude Code local settings + scheduler state
.claude/settings.local.json
.claude/scheduled_tasks.lock

# Supabase CLI cache
supabase/.temp/

# Local environment
.env
!.env.example

# Google services config (contains API keys — add manually per environment)
google-services.json
GoogleService-Info.plist
# OAuth client secret downloads (web client credentials for Supabase config)
client_secret_*.json
# Timestamped google-services backup copies created by Android Studio
google-services.json *.json
